# =============================================================================
# Enclav — copy to .env.local and fill values (never commit .env.local)
# Chain: 0G Aristotle mainnet (16661), RPC https://evmrpc.0g.ai
# =============================================================================

# --- Required for /api/scan (server signer: Storage uploads, Compute broker, deductCredits) ---
DEPLOYER_PRIVATE_KEY=

# --- 0G Compute (OpenAI-compatible proxy — avoids DeepSeek mainnet rate limits) ---
# Mint broker tokens + call https://integratenetwork.work/v1/proxy (see Emmanuel gist pattern).
# ZERO_G_CHAIN_PRIVATE_KEY: same wallet as DEPLOYER_PRIVATE_KEY on Aristotle (tiny OG balance).
ZERO_G_CHAIN_PRIVATE_KEY=
# ZERO_G_COMPUTE_PROVIDER: provider EOA for your OPENAI_MODEL (run `npm run list-providers` for Qwen/GLM addresses).
ZERO_G_COMPUTE_PROVIDER=
ZERO_G_CHAIN_RPC_URL=https://evmrpc.0g.ai
OPENAI_BASE_URL=https://integratenetwork.work/v1/proxy
# Match provider catalog: e.g. qwen3.6-plus, glm-4-plus (see list-providers output).
OPENAI_MODEL=qwen3.6-plus

# Legacy naming (still supported — ZERO_G_COMPUTE_PROVIDER wins when both set):
# OG_COMPUTE_PROVIDER: optional when the broker can read providers from chain (same network as OG_RPC_URL).
OG_COMPUTE_PROVIDER=

# --- Optional: GitHub API (higher rate limits for public repo tree + blobs) ---
GITHUB_TOKEN=

# --- 0G RPC (defaults: Aristotle mainnet) ---
OG_RPC_URL=https://evmrpc.0g.ai
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc.0g.ai
OG_CHAIN_ID=16661
NEXT_PUBLIC_OG_CHAIN_ID=16661
OG_EXPLORER=https://chainscan.0g.ai
NEXT_PUBLIC_OG_EXPLORER=https://chainscan.0g.ai

# Optional: Galileo testnet (multi-chain wallet + Hardhat `ogGalileo`)
# OG_GALILEO_RPC_URL=https://evmrpc-testnet.0g.ai
# OG_GALILEO_EXPLORER_URL=https://chainscan-galileo.0g.ai
# OG_GALILEO_CHAIN_ID=16602
# NEXT_PUBLIC_OG_GALILEO_CHAIN_ID=16602

# --- 0G Storage (@0gfoundation/0g-ts-sdk Indexer) ---
OG_STORAGE_INDEXER_URL=https://indexer-storage-turbo.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai

# --- 0G Compute overrides (optional) ---
# OG_COMPUTE_MODEL=deepseek-chat-v3-0324
# OG_COMPUTE_API_BASE_URL=https://indexer-storage-turbo.0g.ai

# --- Contracts on Aristotle mainnet ---
INFT_CONTRACT_ADDRESS=0x0dd0aE98b0e4Dd46cE8B2aa3A2e9a2feAC503EB5
NEXT_PUBLIC_INFT_CONTRACT_ADDRESS=0x0dd0aE98b0e4Dd46cE8B2aa3A2e9a2feAC503EB5
# Comma-separated extra INFT addresses for /agent-id history queries (optional)
# NEXT_PUBLIC_LEGACY_INFT_CONTRACT_ADDRESSES=
CREDITS_CONTRACT_ADDRESS=0xD0ad553838F8b8ac5CFdccA33588c7723d6Bc073
NEXT_PUBLIC_CREDITS_CONTRACT_ADDRESS=0xD0ad553838F8b8ac5CFdccA33588c7723d6Bc073

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
