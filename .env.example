# =============================================================================
# Enclav — copy to .env.local and fill values (never commit .env.local)
# Chain: 0G Galileo testnet (16602), RPC https://evmrpc-testnet.0g.ai
# =============================================================================

# --- Required for /api/scan (server signer: Storage uploads, Compute broker, deductCredits) ---
DEPLOYER_PRIVATE_KEY=

# --- Required for scans (0G Compute provider 0x address from your 0G Compute setup) ---
OG_COMPUTE_PROVIDER=
# Legacy alias still read by code:
# ZEROG_COMPUTE_PROVIDER=

# --- Optional: GitHub API (higher rate limits for public repo tree + blobs) ---
GITHUB_TOKEN=

# --- 0G RPC (defaults to Galileo testnet if unset) ---
OG_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Mainnet (uncomment when deploying to mainnet)
# OG_RPC_URL=https://evmrpc.0g.ai
# OG_CHAIN_ID=16661
# OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai
# OG_EXPLORER=https://chainscan.0g.ai
# NEXT_PUBLIC_OG_CHAIN_ID=16661

# --- 0G Storage (@0gfoundation/0g-ts-sdk Indexer) ---
OG_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# --- 0G Compute overrides (optional) ---
# OG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
# OG_COMPUTE_API_BASE_URL=https://indexer-storage-testnet-turbo.0g.ai

# --- Contracts on Galileo (defaults match deployed Enclav + EnclavCredits) ---
NEXT_PUBLIC_INFT_CONTRACT_ADDRESS=0x8E2225136CaAf9aD28dDBF86e9280DB326AB2464
CREDITS_CONTRACT_ADDRESS=0x502f013010F0229199dFb937C5c783337C5De3EE
NEXT_PUBLIC_CREDITS_CONTRACT_ADDRESS=0x502f013010F0229199dFb937C5c783337C5De3EE

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
